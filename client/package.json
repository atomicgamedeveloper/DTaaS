{
  "name": "@into-cps-association/dtaas-web",
  "version": "1.3.0",
  "description": "Web client for Digital Twin as a Service (DTaaS)",
  "main": "index.tsx",
  "author": "prasadtalasila <prasad.talasila@gmail.com> (http://prasad.talasila.in/)",
  "contributors": [
    "Asger Busk Breinholm",
    "Cesar Vela",
    "Emre Temel",
    "Enok Maj",
    "Marcus Neble Jensen",
    "Mathias Brændgaard",
    "Omar Suleiman",
    "Vanessa Scherma"
  ],
  "license": "The INTO-CPS Association License",
  "private": false,
  "type": "module",
  "scripts": {
    "analyze": "yarn build && npx source-map-explorer 'build/assets/*.js'",
    "build": "vite build --sourcemap",
    "build:fast": "vite build",
    "clean": "npx rimraf build/ dist/ coverage/ playwright-report/ test-results/ test.svg src.svg",
    "clean:all": "yarn clean && npx rimraf node_modules/",
    "config:dev": "npx shx cp config/dev.js public/env.js && npx shx cp config/dev.js build/env.js",
    "config:local": "npx shx cp config/local.js public/env.js && npx shx cp config/local.js build/env.js",
    "config:prod": "npx shx cp config/prod.js public/env.js && npx shx cp config/prod.js build/env.js",
    "config:test": "npx shx cp config/test.js public/env.js && npx shx cp config/test.js build/env.js",
    "develop": "vite",
    "format": "prettier --ignore-path ../.gitignore --write \"**/*.{ts,tsx,css,scss}\"",
    "graph": "npx madge --image src.svg src && npx madge --image test.svg test",
    "start": "vite preview",
    "stop": "npx kill-port 4000",
    "syntax": "npx eslint . --fix",
    "prep": "qlty fmt && yarn format && yarn syntax && qlty check --fix && yarn test:all",
    "test:all": "yarn test:unit && yarn test:int && yarn test:e2e",
    "test:e2e:ext": "cross-env ext=true yarn test:e2e",
    "test:e2e": "yarn config:test && yarn build && playwright test -c ./playwright.config.ts",
    "test:coverage:int-unit": "npx istanbul-merge --out coverage/all/coverage.json coverage/unit/coverage-final.json coverage/int/coverage-final.json && npx nyc report --reporter=lcov --reporter=text --reporter=json -t coverage/all --report-dir coverage/all",
    "test:int": "jest -c ./jest.config.json --coverage --coverageDirectory=coverage/int ../test/integration --setupFilesAfterEnv ./test/integration/jest.setup.ts",
    "test:unit": "jest -c ./jest.config.json --coverageDirectory=coverage/unit ../test/unit --setupFilesAfterEnv ./test/unit/jest.setup.ts"
  },
  "prettier": {
    "singleQuote": true
  },
  "resolutions": {
    "react-is": "^19.2.0",
    "node-forge": "^1.3.2",
    "baseline-browser-mapping": "^2.10.0",
    "fast-uri": "^4.0.0",
    "@babel/plugin-transform-modules-systemjs": "7.29.7"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.8",
    "@gitbeaker/rest": "^43.8.0",
    "@monaco-editor/react": "4.7.0",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "@mui/system": "9.0.0",
    "@mui/x-tree-view": "9.0.2",
    "@reduxjs/toolkit": "^2.10.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/remarkable": "^2.0.8",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "10.1.0",
    "dotenv": "^17.2.3",
    "http-status-codes": "2.3.0",
    "katex": "^0.17.0",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.3.2",
    "oidc-client-ts": "^3.4.1",
    "postcss-normalize": "^13.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-iframe": "^1.8.5",
    "react-is": "^19.2.0",
    "react-oidc-context": "^3.3.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.6",
    "react-syntax-highlighter": "^16.1.0",
    "react-tabs": "^6.1.0",
    "redux": "^5.0.1",
    "remarkable": "^2.0.1",
    "remarkable-katex": "^1.2.1",
    "reselect": "^5.1.1",
    "serve": "^14.2.5",
    "styled-components": "^6.1.19",
    "typescript": "6.0.3",
    "uuid": "14.0.0",
    "vite": "^8.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "baseline-browser-mapping": "^2.10.0",
    "browserslist": "^4.28.1",
    "eslint": "^10.2.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "istanbul-merge": "^2.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "monocart-coverage-reports": "2.12.12",
    "nyc": "^18.0.0",
    "playwright": "^1.60.0",
    "prettier": "3.8.4",
    "shx": "0.4.0",
    "ts-jest": "29.4.11",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
