# OAuth2/OIDC Configuration for Traefik Forward Auth
# Copy this file to .env and fill in your actual values

# Server Configuration
# Replace with your domain name
SERVER_DNS=intocps.org

# Username Configuration
# These usernames will be used as path prefixes for user workspaces
# Example: https://intocps.org/user1, https://foo.com/user2
USERNAME1=user1
USERNAME2=user2

# Secret key for encrypting OAuth session data
# This will be used by traefik-forward-auth to encrypt
# session cookies and data.
# Generate a random string (at least 16 characters)
# Example: openssl rand -base64 32
OAUTH_SECRET=your_random_secret_key_here

# ===================================================================
# KEYCLOAK CONFIGURATION
# ===================================================================

# Keycloak Admin Credentials (for initial setup only)
# Set a strong, unique admin password before running in any environment
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Realm Configuration
# The realm name where your application and users are configured
KEYCLOAK_REALM=dtaas

# Keycloak Issuer URL
# IMPORTANT:
# - This MUST be the public HTTPS issuer URL that Keycloak advertises in the
#   realm's OIDC configuration (and in the token 'iss' claim), e.g. the value
#   you see under "OpenID Endpoint Configuration" in the Keycloak admin UI.
# - Do NOT change this to the internal container URL (e.g. http://keycloak:8080/...).
#   traefik-forward-auth may connect to Keycloak over plain HTTP internally to
#   avoid TLS cert issues, but that internal URL is configured elsewhere in the
#   deployment. This variable must always match the external HTTPS issuer.
KEYCLOAK_ISSUER_URL=https://intocps.org/auth/realms/dtaas

# Keycloak OIDC Client Configuration
# Create a client in your Keycloak realm with:
# - Client ID: dtaas-workspace
# - Access Type: confidential
# - Valid Redirect URIs: https://intocps.org/_oauth/* (or your domain)
# - Web Origins: https://intocps.org (or your domain)
KEYCLOAK_CLIENT_ID=dtaas-workspace
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here
